{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CreatedUser",
  "type": "object",
  "required": ["name", "job", "id", "createdAt"],
  "properties": {
    "name":      { "type": "string" },
    "job":       { "type": "string" },
    "id":        { "type": "string" },
    "createdAt": { "type": "string", "format": "date-time" },
    "_meta": { "$ref": "_meta.json" }
  },
  "additionalProperties": false
}
